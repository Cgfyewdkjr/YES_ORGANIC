<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>YKS Corporation: Манифест Будущего Музыки</title>
    <style>
        :root {
            --neon-red: #ff004c; /* Красный для акцентов и предупреждений */
            --neon-green: #00ff8c; /* Зеленый для роста, достижений, целей */
            --neon-blue: #00bfff; /* Синий для философии, общих заголовков, основного бренда */
            --text-white: #ffffff; /* Белый для основного текста */
            --bg-dark: #0a0a0a;
            --bg-light-dark: #1a1a1a;
            --border-light: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(255, 255, 255, 0.04);
            --glass-blur: blur(8px);
        }
        body {
            font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
            font-size: 13px;
            line-height: 1.6;
            color: var(--text-white);
            margin: 0;
            padding: 0;
            background-color: var(--bg-dark);
            -webkit-print-color-adjust: exact; /* Для печати фоновых цветов */
            color-adjust: exact;
        }
        .page {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm 18mm 20mm 18mm;
            margin: 0 auto;
            box-sizing: border-box;
            background: var(--bg-dark);
            border: 1px solid var(--border-light);
            box-shadow: 0 0 15px rgba(0, 191, 255, 0.1);
            page-break-after: always;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }
        @media print {
            body { background: none; }
            .page {
                border: none;
                margin: 0;
                padding: 15mm;
                box-shadow: none;
                page-break-after: always;
                width: auto;
                min-height: auto;
            }
        }
        h1, h2, h3, h4 { margin: 0 0 10px 0; font-weight: 700; text-align: left; }
        h1 { font-size: 44px; text-transform: uppercase; letter-spacing: 4px; color: var(--neon-blue); text-shadow: 0 0 10px var(--neon-blue), 0 0 20px rgba(0,191,255,0.4); margin-bottom: 20px; }
        h2 { font-size: 28px; color: var(--neon-green); text-shadow: 0 0 8px var(--neon-green), 0 0 15px rgba(0,255,140,0.3); margin-bottom: 15px; }
        h3 { font-size: 22px; color: var(--neon-red); text-shadow: 0 0 6px var(--neon-red), 0 0 12px rgba(255,0,76,0.3); margin-bottom: 10px; }
        h4 { font-size: 18px; color: var(--neon-blue); text-shadow: 0 0 5px var(--neon-blue); margin-bottom: 8px; }
        p { margin: 0 0 12px 0; text-align: justify; color: var(--text-white); }
        .quote { font-style: italic; font-size: 18px; color: var(--neon-red); text-align: center; margin: 30px 0; padding: 15px; border-left: 3px solid var(--neon-red); border-right: 3px solid var(--neon-red); text-shadow: none; }
        .quote::before { content: "«"; font-size: 30px; line-height: 0; vertical-align: bottom; margin-right: 5px; }
        .quote::after { content: "»"; font-size: 30px; line-height: 0; vertical-align: bottom; margin-left: 5px; }
        .quote-author { font-size: 14px; text-align: right; margin-top: 10px; color: var(--neon-blue); }

        .glass-box { background: var(--glass-bg); backdrop-filter: var(--glass-blur); border: 1px solid var(--border-light); padding: 25px; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 0 15px rgba(0, 191, 255, 0.1); }
        .glass-box h4 { margin-top: 0; color: var(--neon-green); text-shadow: none; }
        .glass-box p { color: #e0e0e0; }
        .highlight-red { color: var(--neon-red); text-shadow: 0 0 5px var(--neon-red); font-weight: bold; }
        .highlight-green { color: var(--neon-green); text-shadow: 0 0 5px var(--neon-green); font-weight: bold; }
        .highlight-blue { color: var(--neon-blue); text-shadow: 0 0 5px var(--neon-blue); font-weight: bold; }

        .footer-text { position: absolute; bottom: 15mm; left: 18mm; right: 18mm; font-size: 11px; color: #555; text-align: center; }
        .page-number { position: absolute; bottom: 15mm; right: 18mm; font-size: 11px; color: #555; }

        /* Графики */
        .chart-container { width: 100%; height: 200px; margin-bottom: 25px; display: flex; align-items: flex-end; justify-content: space-around; padding: 10px 0; border-bottom: 1px solid var(--border-light); }
        .bar { width: 15%; background: var(--glass-bg); border: 1px solid var(--border-light); border-radius: 5px 5px 0 0; position: relative; display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--text-white); text-shadow: 0 0 5px var(--text-white); transition: height 0.5s ease-out; }
        .bar-label { position: absolute; top: -20px; font-size: 11px; color: #ccc; }
        .bar-value { position: absolute; bottom: -20px; font-size: 11px; color: #ccc; }
        .bar.red-bar { background: linear-gradient(to top, rgba(255,0,76,0.5), rgba(255,0,76,0.1)); border-color: var(--neon-red); }
        .bar.green-bar { background: linear-gradient(to top, rgba(0,255,140,0.5), rgba(0,255,140,0.1)); border-color: var(--neon-green); }
        .bar.blue-bar { background: linear-gradient(to top, rgba(0,191,255,0.5), rgba(0,191,255,0.1)); border-color: var(--neon-blue); }

        .progress-bar-container { width: 100%; height: 25px; background: var(--glass-bg); border-radius: 5px; overflow: hidden; margin-top: 15px; position: relative; }
        .progress-bar-fill { height: 100%; border-radius: 5px; text-align: right; line-height: 25px; padding-right: 10px; box-sizing: border-box; font-weight: bold; transition: width 0.8s ease-out; }
        .progress-bar-fill span { margin-left: auto; }
        
        .grid-schedule { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-top: 20px; }
        .schedule-item { background: var(--glass-bg); border: 1px solid rgba(255,255,255,0.08); padding: 15px; border-radius: 8px; text-align: center; }
        .schedule-item h4 { margin-top: 0; color: var(--neon-red); font-size: 18px; text-shadow: none; }
        .schedule-item p { font-size: 12px; color: #ccc; margin-bottom: 5px; }
        .schedule-item .percentage { font-size: 24px; font-weight: bold; margin-top: 10px; }
        .schedule-item .bar-small { height: 8px; width: 80%; background: #333; margin: 0 auto; border-radius: 4px; overflow: hidden; }
        .schedule-item .bar-small-fill { height: 100%; border-radius: 4px; }
    </style>
</head>
<body>

    <!-- Страница 1: Титульный лист YKS Corporation -->
    <div class="page" style="justify-content: center; text-align: center;">
        <h1 style="font-size: 60px; line-height: 1.2;">YKS CORPORATION</h1>
        <h2 style="font-size: 36px; margin-top: 20px;">МАНИФЕСТ БУДУЩЕГО МУЗЫКИ</h2>
